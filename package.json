{
  "name": "runql",
  "displayName": "RunQL",
  "description": "SQL workflows, connections, and ERD tooling in VS Code.",
  "publisher": "RunQL-VSCode-Extension",
  "icon": "media/icon.png",
  "author": "Rob Darling",
  "repository": {
    "type": "git",
    "url": "https://github.com/DVCodeLabs/RunQL.git"
  },
  "bugs": {
    "url": "https://github.com/DVCodeLabs/RunQL/issues"
  },
  "homepage": "https://runql.com/opensource/",
  "keywords": [
    "vscode",
    "vscode-extension",
    "sql",
    "duckdb",
    "postgres",
    "mysql",
    "database",
    "etl",
    "analytics",
    "data-engineering",
    "erd",
    "ai"
  ],
  "version": "1.2.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Data Science",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:postgres"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "runql.query.run",
        "key": "shift+cmd+r",
        "when": "editorTextFocus && resourceLangId == sql"
      },
      {
        "command": "runql.query.runCurrentStatement",
        "key": "shift+cmd+enter",
        "when": "editorTextFocus && resourceLangId == sql"
      }
    ],
    "commands": [
      {
        "command": "runql.actionsMenu",
        "title": "RunQL: Actions"
      },
      {
        "command": "runql.welcome.open",
        "title": "RunQL: Open Welcome",
        "icon": "$(rocket)"
      },
      {
        "command": "runql.project.initialize",
        "title": "RunQL: Initialize Project",
        "icon": "$(folder)"
      },
      {
        "command": "runql.connection.add",
        "title": "RunQL: Add Connection",
        "icon": {
          "dark": "media/icons/lucide/dark/clipboard-plus.svg",
          "light": "media/icons/lucide/light/clipboard-plus.svg"
        }
      },
      {
        "command": "runql.connection.edit",
        "title": "RunQL: Edit Connection",
        "icon": {
          "dark": "media/icons/lucide/dark/clipboard-pen-line.svg",
          "light": "media/icons/lucide/light/clipboard-pen-line.svg"
        }
      },
      {
        "command": "runql.connection.remove",
        "title": "RunQL: Remove Connection",
        "icon": {
          "dark": "media/icons/lucide/dark/clipboard-x.svg",
          "light": "media/icons/lucide/light/clipboard-x.svg"
        }
      },
      {
        "command": "runql.connection.test",
        "title": "RunQL: Test Connection",
        "icon": {
          "dark": "media/icons/lucide/dark/clipboard-check.svg",
          "light": "media/icons/lucide/light/clipboard-check.svg"
        }
      },
      {
        "command": "runql.connection.select",
        "title": "RunQL: Set as default for new SQL files",
        "icon": "$(pass)"
      },
      {
        "command": "runql.connection.introspect",
        "title": "RunQL: Refresh Schema (Introspect)",
        "icon": {
          "dark": "media/icons/lucide/dark/rotate-ccw.svg",
          "light": "media/icons/lucide/light/rotate-ccw.svg"
        }
      },
      {
        "command": "runql.view.refreshConnections",
        "title": "RunQL: Refresh Connections",
        "icon": {
          "dark": "media/icons/lucide/dark/rotate-cw.svg",
          "light": "media/icons/lucide/light/rotate-cw.svg"
        }
      },
      {
        "command": "runql.view.refreshSchemas",
        "title": "RunQL: Refresh All Schemas",
        "icon": {
          "dark": "media/icons/lucide/dark/rotate-ccw.svg",
          "light": "media/icons/lucide/light/rotate-ccw.svg"
        }
      },
      {
        "command": "runql.view.refreshSavedQueries",
        "title": "RunQL: Refresh Saved Queries",
        "icon": {
          "dark": "media/icons/lucide/dark/rotate-cw.svg",
          "light": "media/icons/lucide/light/rotate-cw.svg"
        }
      },
      {
        "command": "runql.query.createSqlFile",
        "title": "RunQL: Create SQL File",
        "icon": {
          "dark": "media/icons/lucide/dark/file-plus.svg",
          "light": "media/icons/lucide/light/file-plus.svg"
        }
      },
      {
        "command": "runql.query.run",
        "title": "RunQL: Run Query",
        "icon": {
          "dark": "media/icons/lucide/dark-filled/play.svg",
          "light": "media/icons/lucide/light-filled/play.svg"
        }
      },
      {
        "command": "runql.query.runNoLimit",
        "title": "RunQL: Run Query (No Limit)",
        "icon": {
          "dark": "media/icons/lucide/dark-filled/play.svg",
          "light": "media/icons/lucide/light-filled/play.svg"
        }
      },
      {
        "command": "runql.query.runCurrentStatement",
        "title": "RunQL: Run Current Statement",
        "icon": {
          "dark": "media/icons/lucide/dark-filled/play.svg",
          "light": "media/icons/lucide/light-filled/play.svg"
        }
      },
      {
        "command": "runql.query.openTablePreview",
        "title": "RunQL: Query Top 100",
        "icon": {
          "dark": "media/icons/lucide/dark/play.svg",
          "light": "media/icons/lucide/light/play.svg"
        }
      },
      {
        "command": "runql.schema.createTable",
        "title": "RunQL: Create Table in Schema",
        "icon": {
          "dark": "media/icons/lucide/dark/square-plus.svg",
          "light": "media/icons/lucide/light/square-plus.svg"
        }
      },
      {
        "command": "runql.schema.editTable",
        "title": "RunQL: Edit Table",
        "icon": {
          "dark": "media/icons/lucide/dark/square-pen.svg",
          "light": "media/icons/lucide/light/square-pen.svg"
        }
      },
      {
        "command": "runql.schema.backupSchema",
        "title": "RunQL: Backup Schema",
        "icon": {
          "dark": "media/icons/lucide/dark/database-backup.svg",
          "light": "media/icons/lucide/light/database-backup.svg"
        }
      },
      {
        "command": "runql.query.addInlineComments",
        "title": "RunQL: Add Inline Comments"
      },
      {
        "command": "runql.query.generateMarkdownDoc",
        "title": "RunQL: Create Markdown Description"
      },
      {
        "command": "runql.query.findSimilarSavedQueries",
        "title": "RunQL: A Similar Query Exists",
        "icon": {
          "dark": "media/icons/lucide/dark/search-alert.svg",
          "light": "media/icons/lucide/light/search-alert.svg"
        }
      },
      {
        "command": "runql.schema.generateDescriptionsWithAI",
        "title": "RunQL: Generate Descriptions (AI)",
        "icon": {
          "dark": "media/icons/lucide/dark/book-text.svg",
          "light": "media/icons/lucide/light/book-text.svg"
        }
      },
      {
        "command": "runql.openSettings",
        "title": "RunQL: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "runql.sql.formatDocument",
        "title": "RunQL: Format SQL"
      },
      {
        "command": "runql.ai.selectModel",
        "title": "RunQL: Select AI Model",
        "icon": "$(hubot)"
      },
      {
        "command": "runql.erd.open",
        "title": "RunQL: View ERD (Active Connection)",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "runql.erd.openSchema",
        "title": "RunQL: View ERD (Selected Schema)",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "runql.chart.createFromResults",
        "title": "RunQL: Create Chart from Results (AI)"
      },
      {
        "command": "runql.query.renameBundle",
        "title": "RunQL: Rename Query Bundle",
        "icon": {
          "dark": "media/icons/lucide/dark/file-stack.svg",
          "light": "media/icons/lucide/light/file-stack.svg"
        }
      },
      {
        "command": "runql.schema.toggleSystemSchemas",
        "title": "RunQL: Toggle System Schemas"
      },
      {
        "command": "runql.editor.insertRoutineCall",
        "title": "RunQL: Insert Routine Call"
      },
      {
        "command": "runql.connection.exportToCsv",
        "title": "RunQL: Export to CSV (Generic)",
        "icon": {
          "dark": "media/icons/lucide/dark/download.svg",
          "light": "media/icons/lucide/light/download.svg"
        }
      },
      {
        "command": "runql.memoryRecall.openQuery",
        "title": "RunQL: Open Query from History"
      },
      {
        "command": "runql.query.openMarkdownDoc",
        "title": "RunQL: View Markdown Documentation",
        "icon": "$(markdown)"
      },
      {
        "command": "runql.query.deleteSaved",
        "title": "RunQL: Delete Saved Query",
        "icon": {
          "dark": "media/icons/lucide/dark/trash.svg",
          "light": "media/icons/lucide/light/trash.svg"
        }
      },
      {
        "command": "runql.schema.selectForCompare",
        "title": "Select for Compare"
      },
      {
        "command": "runql.schema.compareWithSelected",
        "title": "Compare with Selected"
      },
      {
        "command": "runql.schema.compareSchemas",
        "title": "RunQL: Compare Schemas..."
      },
      {
        "command": "runql.schema.compareTables",
        "title": "RunQL: Compare Tables..."
      },
      {
        "command": "runql.schema.clearCompareSelection",
        "title": "RunQL: Clear Compare Selection"
      },
      {
        "command": "runql.query.search.focus",
        "title": "RunQL: Focus Query Search"
      },
      {
        "command": "runql.query.search.clear",
        "title": "RunQL: Clear Query Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "runql.query.search.rebuildIndex",
        "title": "RunQL: Rebuild Search Index",
        "icon": {
          "dark": "media/icons/lucide/dark/rotate-cw.svg",
          "light": "media/icons/lucide/light/rotate-cw.svg"
        }
      }
    ],
    "configuration": {
      "title": "RunQL",
      "properties": {
        "runql.query.maxRowsLimit": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "description": "RunQL: Hard LIMIT for rows returned by SELECT queries. Set to 0 for no LIMIT. Use the 'Run (no LIMIT)' button in an sql file to bypass this setting."
        },
        "runql.results.editing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Enable inline editing and save-back in resultsets when connection and result safety checks allow it."
        },
        "runql.ai.provider": {
          "type": "string",
          "enum": [
            "none",
            "vscode",
            "openai",
            "anthropic",
            "azureOpenAI",
            "ollama",
            "openaiCompatible"
          ],
          "default": "vscode",
          "description": "RunQL: AI provider selection."
        },
        "runql.ai.model": {
          "type": "string",
          "default": "gpt-4o",
          "markdownDescription": "RunQL: Model name (provider-specific). Use command [RunQL: Select AI Model](command:runql.ai.selectModel) to choose from all active VS Code models."
        },
        "runql.ai.endpoint": {
          "type": "string",
          "default": "",
          "description": "RunQL: Custom endpoint for openaiCompatible or local providers."
        },
        "runql.ai.sendSchemaContext": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Include schema + meta + relationships in AI prompts."
        },
        "runql.ai.maxSchemaChars": {
          "type": "number",
          "default": 150000,
          "minimum": 1000,
          "description": "RunQL: Approximate cap for schema context payload size (characters)."
        },
        "runql.ui.showRoutines": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Show procedures and functions in the Explorer when introspection metadata is available."
        },
        "runql.ui.showRoutineParameters": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Show routine signature details (parameters) in the Explorer label/tooltip when available."
        },
        "runql.sqlCodelens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Show RunQL actions and connection selector at the top of SQL files."
        },
        "runql.format.enabled": {
          "type": "boolean",
          "default": true,
          "description": "RunQL: Enable SQL formatting features."
        },
        "runql.format.indentSize": {
          "type": "number",
          "default": 2,
          "description": "RunQL: Number of spaces to use for indentation."
        },
        "runql.format.keywordCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "upper",
          "description": "RunQL: Case for SQL keywords."
        },
        "runql.format.dialectFallback": {
          "type": "string",
          "enum": [
            "postgresql",
            "mysql",
            "sql"
          ],
          "default": "sql",
          "description": "RunQL: Fallback dialect to use if no active connection is selected."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "runql",
          "title": "RunQL",
          "icon": "media/runql_logo2.svg"
        }
      ],
      "panel": [
        {
          "id": "runql-results",
          "title": "RunQL: Data Results",
          "icon": "media/runql_logo2.svg"
        },
        {
          "id": "runql-erd",
          "title": "RunQL: ERD",
          "icon": "media/runql_logo2.svg"
        },
        {
          "id": "runql-memory-recall",
          "title": "RunQL: Query History",
          "icon": "media/runql_logo2.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "runql.explorerViewBuiltin",
          "name": "RunQL Explorer",
          "icon": "$(plug)",
          "visibility": "visible"
        }
      ],
      "runql": [
        {
          "id": "runql.explorerView",
          "name": "Explorer",
          "icon": "$(plug)",
          "visibility": "visible"
        },
        {
          "id": "runql.querySearchView",
          "name": "Query Search",
          "type": "webview",
          "icon": "$(search)"
        },
        {
          "id": "runql.savedQueriesView",
          "name": "Saved Queries",
          "icon": "$(file-code)"
        }
      ],
      "runql-results": [
        {
          "id": "runql.resultsView",
          "name": "RunQL: Results",
          "type": "webview",
          "icon": "$(table)"
        }
      ],
      "runql-erd": [
        {
          "id": "runql.erdView",
          "name": "RunQL: ERD",
          "type": "webview",
          "icon": "$(type-hierarchy)"
        }
      ],
      "runql-memory-recall": [
        {
          "id": "runql.memoryRecallView",
          "name": "RunQL: History",
          "icon": "$(history)"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "runql.query.findSimilarSavedQueries",
          "when": "resourceLangId == sql && runql.hasSimilarQueries",
          "group": "navigation"
        },
        {
          "command": "runql.query.run",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "runql.query.openMarkdownDoc",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "runql.query.createSqlFile",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "runql.query.renameBundle",
          "when": "view == runql.savedQueriesView && viewItem == queryItem",
          "group": "inline@1"
        },
        {
          "command": "runql.query.deleteSaved",
          "when": "view == runql.savedQueriesView && viewItem == queryItem",
          "group": "inline@2"
        },
        {
          "command": "runql.connection.introspect",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.connection",
          "group": "inline"
        },
        {
          "command": "runql.schema.createTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@0"
        },
        {
          "command": "runql.schema.createTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.folder.tables",
          "group": "inline@0"
        },
        {
          "command": "runql.connection.introspect",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@1"
        },
        {
          "command": "runql.schema.generateDescriptionsWithAI",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@3"
        },
        {
          "command": "runql.erd.openSchema",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@2"
        },
        {
          "command": "runql.schema.backupSchema",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@4"
        },
        {
          "command": "runql.connection.select",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "inline@1"
        },
        {
          "command": "runql.connection.test",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "inline@3"
        },
        {
          "command": "runql.connection.edit",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "inline@4"
        },
        {
          "command": "runql.connection.remove",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "inline@5"
        },
        {
          "command": "runql.query.openTablePreview",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && (viewItem == runql.schema.table || viewItem == runql.schema.table.reserved || viewItem == runql.schema.table.noexport)",
          "group": "inline@0"
        },
        {
          "command": "runql.schema.editTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && (viewItem == runql.schema.table || viewItem == runql.schema.table.reserved || viewItem == runql.schema.table.noexport)",
          "group": "inline@1"
        },
        {
          "command": "runql.connection.exportToCsv",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.table",
          "group": "inline@2"
        },
        {
          "command": "runql.editor.insertRoutineCall",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && (viewItem == runql.schema.procedure || viewItem == runql.schema.function)",
          "group": "inline@0"
        },
        {
          "command": "runql.schema.selectForCompare",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem =~ /runql\\.schema\\.(schema|table|view|table\\.noexport|table\\.reserved)/",
          "group": "compare@1"
        },
        {
          "command": "runql.schema.compareWithSelected",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem =~ /runql\\.schema\\.(schema|table|view|table\\.noexport|table\\.reserved)/ && runql.compareSourceSet",
          "group": "compare@2"
        },

        {
          "command": "runql.connection.select",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "1_connect@1"
        },
        {
          "command": "runql.connection.test",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "1_connect@2"
        },
        {
          "command": "runql.connection.edit",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "2_manage@1"
        },
        {
          "command": "runql.connection.remove",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.connection.item",
          "group": "2_manage@2"
        },

        {
          "command": "runql.schema.createTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.folder.tables",
          "group": "1_schema@1"
        },

        {
          "command": "runql.connection.introspect",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "1_schema@1"
        },
        {
          "command": "runql.schema.createTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "1_schema@2"
        },
        {
          "command": "runql.erd.openSchema",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "2_view@1"
        },
        {
          "command": "runql.schema.generateDescriptionsWithAI",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "2_view@2"
        },
        {
          "command": "runql.schema.backupSchema",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "3_export@1"
        },

        {
          "command": "runql.query.openTablePreview",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && (viewItem == runql.schema.table || viewItem == runql.schema.table.noexport || viewItem == runql.schema.table.reserved)",
          "group": "1_query@1"
        },
        {
          "command": "runql.schema.editTable",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && (viewItem == runql.schema.table || viewItem == runql.schema.table.noexport || viewItem == runql.schema.table.reserved)",
          "group": "2_manage@1"
        },
        {
          "command": "runql.connection.exportToCsv",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.table",
          "group": "3_export@1"
        }
      ],
      "view/title": [
        {
          "command": "runql.connection.add",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin)",
          "group": "navigation@1"
        },
        {
          "command": "runql.view.refreshSchemas",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin)",
          "group": "navigation@2"
        },
        {
          "command": "runql.ai.selectModel",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin)",
          "group": "navigation@3"
        },
        {
          "command": "runql.openSettings",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin)",
          "group": "navigation@4"
        },
        {
          "command": "runql.schema.generateDescriptionsWithAI",
          "when": "(view == runql.explorerView || view == runql.explorerViewBuiltin) && viewItem == runql.schema.schema",
          "group": "inline@10"
        },
        {
          "command": "runql.query.search.clear",
          "when": "view == runql.querySearchView",
          "group": "navigation@1"
        },
        {
          "command": "runql.query.search.rebuildIndex",
          "when": "view == runql.querySearchView",
          "group": "navigation@2"
        },
        {
          "command": "runql.view.refreshSavedQueries",
          "when": "view == runql.savedQueriesView",
          "group": "navigation@10"
        },
        {
          "command": "runql.query.createSqlFile",
          "when": "view == runql.savedQueriesView",
          "group": "navigation@9"
        },
        {
          "command": "runql.erd.open",
          "when": "view == runql.erdView && runql.hasActiveSchema",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
